<<test functions>>=
class TestInitialize:
    def test_creates_learnlog_repo(self, workdir, test_env):
        script = workdir / "test_init.py"
        script.write_text(
            "import learnlog\n"
            "print('hello')\n"
        )
        result = subprocess.run(
            [sys.executable, str(script)],
            cwd=str(workdir), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        assert result.returncode == 0
        assert (workdir / ".learnlog").is_dir()

    def test_stdout_still_works(self, workdir, test_env):
        script = workdir / "test_stdout.py"
        script.write_text(
            "import learnlog\n"
            "print('visible')\n"
        )
        result = subprocess.run(
            [sys.executable, str(script)],
            cwd=str(workdir), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        assert "visible" in result.stdout

    def test_skips_when_running_as_cli(self, workdir, test_env):
        """Simulates sys.argv[0] being 'learnlog'."""
        script = workdir / "test_cli_skip.py"
        script.write_text(
            "import sys\n"
            "sys.argv = ['learnlog', 'play']\n"
            "import learnlog\n"
            "assert learnlog.repo is None\n"
        )
        result = subprocess.run(
            [sys.executable, str(script)],
            cwd=str(workdir), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        assert result.returncode == 0

    def test_uses_existing_repo_from_subdirectory(
        self, workdir, test_env
    ):
        """When .learnlog/ exists in a parent, initialisation
        uses that repository instead of creating a new one."""
        script = workdir / "setup.py"
        script.write_text(
            "import learnlog\n"
            "print('setup')\n"
        )
        result = subprocess.run(
            [sys.executable, str(script)],
            cwd=str(workdir), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        assert result.returncode == 0
        sub = workdir / "lab1"
        sub.mkdir()
        child = sub / "hello.py"
        child.write_text(
            "import learnlog\n"
            "print('from sub')\n"
        )
        result = subprocess.run(
            [sys.executable, str(child)],
            cwd=str(sub), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        assert result.returncode == 0
        assert not (sub / ".learnlog").is_dir()
        git_result = subprocess.run(
            ["git", "--git-dir=.learnlog",
             "--work-tree=.", "log", "--oneline"],
            cwd=str(workdir),
            capture_output=True, text=True,
        )
        assert "hello.py" in git_result.stdout
