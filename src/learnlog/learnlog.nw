\section{Exception handling}

We install a custom [[sys.excepthook]] to capture unhandled exceptions
before the program terminates.
The hook records the exception details and then calls the original hook
so that the traceback is still printed normally.

Why not just inspect [[sys.exc_info()]] in the exit handler?
Because by the time [[atexit]] handlers run, the exception has already
been cleared.
The [[excepthook]] fires while the exception is still active, giving us
access to the full traceback.

<<install exception hook>>=
original_excepthook = sys.excepthook

def exception_hook(exc_type, exc_value, exc_tb):
    global exception_info
    exception_info = "".join(
        traceback.format_exception(
            exc_type, exc_value, exc_tb
        )
    )
    original_excepthook(exc_type, exc_value, exc_tb)

sys.excepthook = exception_hook
@

Let's verify that exceptions are captured and the traceback is still
printed:

<<test functions>>=
class TestExceptionCapture:
    def test_exception_recorded_in_commit(self, workdir, test_env):
        script = workdir / "test_exc.py"
        script.write_text(
            "import learnlog\n"
            "raise ValueError('test error')\n"
        )
        result = subprocess.run(
            [sys.executable, str(script)],
            cwd=str(workdir), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        assert result.returncode != 0
        assert "ValueError" in result.stderr

        # Check the commit message
        git_result = subprocess.run(
            ["git", "--git-dir=.learnlog",
             "--work-tree=.", "log", "-1", "--format=%B"],
            cwd=str(workdir),
            capture_output=True, text=True,
        )
        assert "ValueError: test error" in git_result.stdout
@


\section{Exit handler}

The [[on_exit]] function runs when the program terminates (via
[[atexit]]).
It restores the original streams---we must do this before running Git
commands, otherwise our own output would be captured recursively---and
then finalises the run in the repository.

We wrap everything in a [[try]]/[[except]] for the same reason as
[[initialize]]: learnlog must never cause an error at exit.

<<functions>>=
def on_exit():
    """Finalise the learnlog entry on program exit.

    Restores original streams and commits the I/O log, exception
    information, and exit status.
    """
    global repo, iolog, exception_info
    global original_stdout, original_stderr, original_stdin

    if repo is None:
        return

    try:
        <<restore original streams>>
        <<finalise the run>>
    except Exception:
        pass
@

<<restore original streams>>=
if original_stdout is not None:
    sys.stdout = original_stdout
if original_stderr is not None:
    sys.stderr = original_stderr
if original_stdin is not None:
    sys.stdin = original_stdin
@

<<finalise the run>>=
end_time = datetime.datetime.now()
io_text = iolog.getvalue() if iolog else ""
repo.finalize_run(
    io_log=io_text,
    exception_info=exception_info,
    end_time=end_time,
    exit_code=0 if exception_info is None else 1,
)
@

Let's verify the full lifecycle: import, run, exit, and check the
commit:

<<test functions>>=
class TestOnExit:
    def test_commit_has_io_log(self, workdir, test_env):
        script = workdir / "test_io.py"
        script.write_text(
            "import learnlog\n"
            "print('logged output')\n"
        )
        result = subprocess.run(
            [sys.executable, str(script)],
            cwd=str(workdir), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        assert result.returncode == 0

        git_result = subprocess.run(
            ["git", "--git-dir=.learnlog",
             "--work-tree=.", "log", "-1", "--format=%B"],
            cwd=str(workdir),
            capture_output=True, text=True,
        )
        msg = git_result.stdout
        assert "stdout: logged output" in msg
        assert "End-Time:" in msg
        assert "Exit-Code: 0" in msg

    def test_commit_has_run_metadata(self, workdir, test_env):
        script = workdir / "test_meta.py"
        script.write_text(
            "import learnlog\n"
        )
        result = subprocess.run(
            [sys.executable, str(script), "arg1", "arg2"],
            cwd=str(workdir), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        assert result.returncode == 0

        git_result = subprocess.run(
            ["git", "--git-dir=.learnlog",
             "--work-tree=.", "log", "-1", "--format=%B"],
            cwd=str(workdir),
            capture_output=True, text=True,
        )
        msg = git_result.stdout
        assert "Script: test_meta.py" in msg
        assert "arg1 arg2" in msg

    def test_no_change_between_runs(self, workdir, test_env):
        script = workdir / "test_amend.py"
        script.write_text(
            "import learnlog\n"
            "print('same')\n"
        )
        # Run twice without editing
        for _ in range(2):
            subprocess.run(
                [sys.executable, str(script)],
                cwd=str(workdir), env=test_env,
                capture_output=True, text=True, timeout=30,
            )
        git_result = subprocess.run(
            ["git", "--git-dir=.learnlog",
             "--work-tree=.", "log", "--oneline"],
            cwd=str(workdir),
            capture_output=True, text=True,
        )
        lines = git_result.stdout.strip().split("\n")
        assert len(lines) == 1  # single commit, two runs amended

    def test_new_commit_after_edit(self, workdir, test_env):
        script = workdir / "test_edit.py"
        script.write_text(
            "import learnlog\n"
            "print('v1')\n"
        )
        subprocess.run(
            [sys.executable, str(script)],
            cwd=str(workdir), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        # Edit the file
        script.write_text(
            "import learnlog\n"
            "print('v2')\n"
        )
        subprocess.run(
            [sys.executable, str(script)],
            cwd=str(workdir), env=test_env,
            capture_output=True, text=True, timeout=30,
        )
        git_result = subprocess.run(
            ["git", "--git-dir=.learnlog",
             "--work-tree=.", "log", "--oneline"],
            cwd=str(workdir),
            capture_output=True, text=True,
        )
        lines = git_result.stdout.strip().split("\n")
        assert len(lines) == 2
