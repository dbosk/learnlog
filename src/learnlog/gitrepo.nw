\section{Formatting the run trailer}

The trailer is appended by [[finalize_run]] and contains the end time,
exit code, I/O log, and exception information.

<<functions>>=
def format_run_trailer(io_log, exception_info,
                       end_time, exit_code):
    """Format the trailer appended by :func:`finalize_run`.

    Contains the end time, exit code, I/O log, and exception
    information.
    """
    parts = [
        f"End-Time: {end_time.isoformat()}",
        f"Exit-Code: {exit_code}",
        "",
        "--- I/O ---",
        io_log.rstrip("\n") if io_log else "(no I/O)",
        "",
        "--- exception ---",
    ]
    if exception_info:
        parts.append(exception_info)
    else:
        parts.append("None")
    return "\n".join(parts)
@

Let's verify the format:

<<test functions>>=
def test_format_run_trailer_basic():
    end = datetime.datetime(2026, 1, 1, 10, 0, 5)
    trailer = format_run_trailer(
        "stdout: hello\n", None, end, 0
    )
    assert "End-Time: 2026-01-01T10:00:05" in trailer
    assert "Exit-Code: 0" in trailer
    assert "stdout: hello" in trailer
    assert "None" in trailer

def test_format_run_trailer_with_exception():
    end = datetime.datetime(2026, 1, 1, 10, 0, 1)
    trailer = format_run_trailer(
        "", "ValueError: oops", end, 1
    )
    assert "Exit-Code: 1" in trailer
    assert "ValueError: oops" in trailer
