def test_init_creates_learnlog_dir(workdir):
    repo = LearnlogRepo(workdir)
    assert (workdir / ".learnlog").is_dir()

def test_init_has_initial_commit(workdir):
    repo = LearnlogRepo(workdir)
    result = repo.git("log", "--oneline")
    assert "initial commit" in result.stdout

def test_init_tracks_source_files(workdir):
    repo = LearnlogRepo(workdir)
    result = repo.git("ls-files")
    assert "hello.py" in result.stdout

def test_init_excludes_pycache(workdir):
    pycache = workdir / "__pycache__"
    pycache.mkdir()
    (pycache / "hello.cpython-311.pyc").write_bytes(b"fake")
    repo = LearnlogRepo(workdir)
    result = repo.git("ls-files")
    assert "__pycache__" not in result.stdout

def test_init_reads_learnlogignore(workdir):
    (workdir / ".learnlogignore").write_text("data/\n*.csv\n")
    (workdir / "data").mkdir()
    (workdir / "data" / "big.csv").write_text("a,b,c\n")
    repo = LearnlogRepo(workdir)
    result = repo.git("ls-files")
    assert "big.csv" not in result.stdout

def test_init_is_idempotent(workdir):
    repo1 = LearnlogRepo(workdir)
    repo2 = LearnlogRepo(workdir)
    result = repo2.git("log", "--oneline")
    assert result.stdout.strip().count("\n") == 0
