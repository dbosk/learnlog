\section{Full lifecycle test}

To verify the complete workflow, we simulate two runs: one where the
student has not changed anything (amends), and one after an edit (new
commit):

<<test functions>>=
def test_full_lifecycle(workdir):
    """Simulate two runs: one with changes, one without."""
    repo = LearnlogRepo(workdir)

    # First run (amends initial commit since no change)
    t1 = datetime.datetime(2026, 1, 1, 10, 0)
    repo.begin_run("hello.py", [], t1)
    repo.finalize_run(
        io_log="stdout: hello\n",
        exception_info=None,
        end_time=datetime.datetime(2026, 1, 1, 10, 0, 5),
        exit_code=0,
    )

    # Edit file
    (workdir / "hello.py").write_text('print("v2")\n')

    # Second run (new commit since file changed)
    t2 = datetime.datetime(2026, 1, 1, 10, 5)
    repo.begin_run("hello.py", [], t2)
    repo.finalize_run(
        io_log="stdout: v2\n",
        exception_info=None,
        end_time=datetime.datetime(2026, 1, 1, 10, 5, 2),
        exit_code=0,
    )

    result = repo.git("log", "--oneline")
    lines = result.stdout.strip().split("\n")
    assert len(lines) == 2  # initial+run1, run2
@
