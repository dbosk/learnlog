    from learnlog.progsnap2 import (
        generate_analysis_latex,
        group_edit_run_pairs,
    )
    events = [
        {
            "EventType": "File.Edit",
            "EventID": "1", "Order": "1",
            "SubjectID": "Alice",
            "CodeStateID": "0",
            "ParentEventID": "",
            "X-Tag": "",
            "ProgramOutput": "", "ProgramInput": "",
        },
        {
            "EventType": "Run.Program",
            "EventID": "2", "Order": "2",
            "SubjectID": "Alice",
            "CodeStateID": "0",
            "ParentEventID": "",
            "X-Tag": "",
            "ProgramResult": "Success",
            "X-ExitCode": "0",
            "X-Script": "hello.py",
            "X-Arguments": "",
            "X-ExceptionType": "",
            "X-ExceptionMessage": "",
            "ProgramOutput": "", "ProgramInput": "",
        },
    ]
    dataset = {
        "metadata": {},
        "events": events,
        "code_states": {
            "0": {"hello.py": 'print("hello")\n'},
        },
        "resources": {},
    }
    grouped = group_edit_run_pairs(events)
    latex = generate_analysis_latex(
        dataset, grouped, side_by_side=True,
    )
    assert "\\begin{paracol}{2}" in latex
    assert "\\switchcolumn[0]" in latex
    assert "\\switchcolumn[1]" in latex
    assert "\\end{paracol}" in latex

def test_generate_analysis_latex_standalone():
    """Standalone mode wraps in documentclass."""
    from learnlog.progsnap2 import (
        generate_analysis_latex,
    )
    dataset = {
        "metadata": {},
        "events": [],
        "code_states": {},
        "resources": {},
    }
    latex = generate_analysis_latex(
        dataset, {}, standalone=True,
    )
    assert "\\documentclass{article}" in latex
    assert "\\usepackage{minted}" in latex
    assert "\\usepackage{paracol}" in latex
    assert "\\end{document}" in latex

def test_format_edit_latex_first_edit():
    """First edit shows full file content."""
    from learnlog.progsnap2 import format_edit_latex
    pair = {
        "edit": {"EventID": "1"},
        "run": None,
        "io": [],
        "code_state_id": "0",
    }
    code_states = {
        "0": {"hello.py": 'print("hello")\n'},
    }
    result = format_edit_latex(pair, None, code_states)
    assert "\\begin{minted}{python}" in result
    assert "\\texttt{hello.py}" in result
    assert "% hello.py" not in result
    assert 'print("hello")' in result

def test_latex_escape_handles_backslash_and_braces():
    """Escaping backslashes does not double-escape braces."""
    from learnlog.progsnap2 import _latex_escape
    result = _latex_escape(r"a\\b{c}")
    assert result == r"a\textbackslash{}\textbackslash{}b\{c\}"

def test_format_edit_latex_diff():
    """Subsequent edit shows unified diff."""
    from learnlog.progsnap2 import format_edit_latex
    prev_pair = {
        "edit": {"EventID": "1"},
        "run": None,
        "io": [],
        "code_state_id": "0",
    }
    pair = {
        "edit": {"EventID": "2"},
        "run": None,
        "io": [],
        "code_state_id": "1",
    }
    code_states = {
        "0": {"hello.py": 'print("hello")\n'},
        "1": {"hello.py": 'print("world")\n'},
    }
    result = format_edit_latex(
        pair, prev_pair, code_states,
    )
    assert "\\begin{minted}{diff}" in result
    assert "-" in result
    assert "+" in result

def test_format_run_latex_with_io():
    """Run with I/O shows script info and minted block."""
    from learnlog.progsnap2 import format_run_latex
    pair = {
        "edit": None,
        "run": {
            "EventID": "2",
            "X-Script": "hello.py",
            "ProgramResult": "Success",
            "X-ExitCode": "0",
            "X-ExceptionType": "",
            "X-ExceptionMessage": "",
        },
        "io": [
            {
                "EventType": "X-Run.Output",
                "ProgramOutput": "Resources/io_3.txt",
                "ProgramInput": "",
            },
            {
                "EventType": "X-Run.Input",
                "ProgramOutput": "",
                "ProgramInput": "Resources/io_4.txt",
            },
        ],
        "code_state_id": "0",
    }
    resources = {
        "Resources/io_3.txt": "Enter name:",
        "Resources/io_4.txt": "Alice",
    }
    result = format_run_latex(pair, resources)
    assert "hello.py" in result
    assert "Enter name:" in result
    assert "> Alice" in result
