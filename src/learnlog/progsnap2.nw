Tags attached to commits appear in the [[X-Tag]] column of
the exported event table.
We verify that a tagged commit carries the tag name and
that untagged commits have an empty [[X-Tag]] value.

<<progsnap2 test functions>>=
def test_progsnap2_tag_column(workdir):
    """Tagged commits have X-Tag populated."""
    import csv as csv_mod
    from learnlog.progsnap2 import do_export_progsnap2
    from learnlog.commits import get_commits
    repo = LearnlogRepo(workdir)
    t1 = datetime.datetime(2026, 1, 1, 10, 0)
    repo.begin_run("hello.py", [], t1)
    (workdir / "hello.py").write_text(
        'print("v2")\n'
    )
    t2 = datetime.datetime(2026, 1, 1, 10, 5)
    repo.begin_run("hello.py", [], t2)
    commits = get_commits(repo)
    repo.git("tag", "lab1", commits[-1]["hash"])
    output = workdir / "out.progsnap2"
    do_export_progsnap2(repo, output)
    with zipfile.ZipFile(str(output)) as zf:
        main = zf.read(
            "MainTable.csv"
        ).decode("utf-8")
    reader = csv_mod.DictReader(io.StringIO(main))
    events = list(reader)
    tagged = [
        e for e in events
        if e["X-Tag"] == "lab1"
    ]
    assert len(tagged) >= 1
    untagged = [
        e for e in events
        if e["X-Tag"] == ""
    ]
    assert len(untagged) >= 1
