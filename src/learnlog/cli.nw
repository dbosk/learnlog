    name="learnlog",
    help="Review student development logs.",
    no_args_is_help=True,
)

<<typer commands>>
@


\subsection{The [[export]] command}

The [[export]] command resolves the learnlog directory and delegates
to [[do_export]].
We accept an explicit [[-C]] / [[--dir]] option rather than reusing
[[resolve_source]] because export does not need bundle support---we
are \emph{creating} bundles, not reading them.

<<typer commands>>=
@app.command()
def export(
    output: Annotated[
        pathlib.Path,
        typer.Option(
            "--output", "-o",
            help="Output bundle file path.",
        ),
    ] = pathlib.Path(DEFAULT_BUNDLE_NAME),
    directory: Annotated[
        Optional[pathlib.Path],
        typer.Option(
            "--dir", "-C",
            help="Directory containing .learnlog/.",
        ),
    ] = None,
):
    """Export the learnlog repository as a Git bundle."""
    workdir = directory
    if workdir is None:
        workdir = find_learnlog_dir()
        if workdir is None:
            raise SystemExit(
                "No .learnlog/ directory found."
            )
    else:
        workdir = pathlib.Path(workdir).resolve()
        if not (workdir / ".learnlog").is_dir():
            raise SystemExit(
                f"No .learnlog/ directory in {workdir}"
            )

    repo = LearnlogRepo(workdir)
    do_export(repo, output.resolve())
    typer.echo(f"Exported to {output}")
@

<<test functions>>=
