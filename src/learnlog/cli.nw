def test_filter_learnlog_runs_preserves_io_separator():
    """The --- I/O --- marker within a block is not a separator."""
    from learnlog.cli import filter_learnlog_runs
    msg = (
        "Run: hello.py (none)\n\nScript: hello.py\n"
