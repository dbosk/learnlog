\section{The export command}
\label{sec:export}

The export command creates a Git bundle of the [[.learnlog/]]
repository.
A bundle is a single file that contains the complete history
and can be cloned or passed to [[learnlog play]] for playback.
This is the natural serialisation format for a Git repository---it
handles pack files correctly and can be verified with
[[git bundle verify]].

The default output filename is [[learnlog.bundle]], placed in the
current directory.

<<constants>>=
DEFAULT_BUNDLE_NAME = "learnlog.bundle"
@

<<export functions>>=
def do_export(repo, output):
    """Export the learnlog repository as a Git bundle.

    Creates a bundle file at ``output`` containing the full
    commit history.
    """
    result = repo.git(
        "bundle", "create", str(output), "--all"
    )
    if result.returncode != 0:
        raise SystemExit(
            f"Failed to create bundle: {result.stderr}"
        )
@

<<test functions>>=
def test_do_export_creates_bundle(workdir):
    from learnlog.cli import do_export
    repo = LearnlogRepo(workdir)
    bundle = workdir / "test.bundle"
    do_export(repo, bundle)
    assert bundle.exists()
    verify = subprocess.run(
        ["git", "bundle", "verify", str(bundle)],
        capture_output=True,
    )
    assert verify.returncode == 0
