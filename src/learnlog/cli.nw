        app, ["git", "log", "--oneline"]
    )
    assert result.exit_code == 0

def test_git_command_no_learnlog_dir(tmp_path, monkeypatch):
    """Error when no .learnlog/ directory exists."""
    from learnlog.cli import app
    from typer.testing import CliRunner
    monkeypatch.chdir(tmp_path)
    runner = CliRunner()
    result = runner.invoke(app, ["git", "log"])
    assert result.exit_code == 1

def test_git_command_forwards_exit_code(
    workdir, monkeypatch
):
    """Git's exit code is propagated."""
    from learnlog.cli import app
    from typer.testing import CliRunner
    repo = LearnlogRepo(workdir)
    monkeypatch.chdir(workdir)
    runner = CliRunner()
    result = runner.invoke(
        app, ["git", "log", "--invalid-option"]
    )
    assert result.exit_code != 0
