def test_resolve_source_bundle(workdir):
    import shutil
    from learnlog.cli import resolve_source
    repo = LearnlogRepo(workdir)
    bundle_path = workdir / "test.bundle"
    repo.git(
        "bundle", "create", str(bundle_path), "--all"
    )
    resolved, tmpdir = resolve_source(str(bundle_path))
    try:
        assert tmpdir is not None
        result = resolved.git("log", "--oneline")
        assert result.returncode == 0
    finally:
        shutil.rmtree(tmpdir)
