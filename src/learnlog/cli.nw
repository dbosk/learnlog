def test_list_command_all_shows_learnlog(workdir):
    """The --all flag counts learnlog runs too."""
    from learnlog.cli import app
    from typer.testing import CliRunner
    repo = LearnlogRepo(workdir)
    t1 = datetime.datetime(2026, 1, 1, 10, 0)
    repo.begin_run("hello.py", [], t1)
    repo.begin_run("learnlog", ["play"], t1)
    runner = CliRunner()
    # Without --all, the learnlog run is filtered out.
    filtered = runner.invoke(
        app, ["list", str(workdir)]
    )
    assert "(2 runs)" not in filtered.output
    # With --all, both runs are counted.
    unfiltered = runner.invoke(
        app, ["list", "--all", str(workdir)]
    )
    assert unfiltered.exit_code == 0
    assert "(2 runs)" in unfiltered.output
