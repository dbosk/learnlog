        Optional[pathlib.Path],
        typer.Option(
            "--output", "-o",
            help="Output LaTeX file (default: stdout).",
        ),
    ] = None,
    side_by_side: Annotated[
        bool,
        typer.Option(
            "--side-by-side", "-s",
            help=(
                "Show edit/run pairs in two columns: "
                "cause on the left, effect on the "
                "right."
            ),
        ),
    ] = False,
    standalone: Annotated[
        bool,
        typer.Option(
            "--standalone",
            help=(
                "Produce a complete LaTeX document "
                "instead of a fragment."
            ),
        ),
    ] = False,
):
    """Analyse development sessions and generate LaTeX."""
    <<resolve analyse source>>
    <<generate and output latex>>
@

We detect whether the source is a ProgSnap2 zip by checking
[[zipfile.is_zipfile]].
This is more robust than checking the file extension, since
the user might rename the file.
For non-zip sources (directories, bundles), we export to a
temporary file first.

<<resolve analyse source>>=
if source is not None and zipfile.is_zipfile(source):
    dataset = read_progsnap2(source)
else:
    repo, tmpdir = resolve_source(source)
    try:
        ps2_path = tempfile.mktemp(
            suffix=".progsnap2"
        )
        do_export_progsnap2(
            repo, ps2_path,
        )
        dataset = read_progsnap2(ps2_path)
    finally:
